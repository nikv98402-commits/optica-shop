# Optional lead form integration.
# If empty, "Подготовить подбор к визиту" copies the selection locally instead of sending data.
VITE_TALLY_FORM_URL=

# Optional Supabase integration.
# The current MVP works without these values and falls back to local demo data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ViLu Eye Map is gated until the Sprint 0 model, license, privacy, and
# representative-photo checks have passed. Keep false in production by default.
VITE_FEATURE_EYE_MAP=false

# ViLu Knowledge Assistant remains disabled until its reviewed source index,
# Supabase function, and provider secrets are ready in the target environment.
VITE_FEATURE_KNOWLEDGE_ASSISTANT=false

# Supabase Edge Function secrets are configured in Supabase, not in Vite.
# Never expose SUPABASE_SERVICE_ROLE_KEY in frontend code.
# SUPABASE_SERVICE_ROLE_KEY=
# PAYMENT_PROVIDER=none

# Future YooKassa server-only secrets. Configure them in Supabase Edge Function
# secrets, never as VITE_* variables and never commit real values.
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=https://vilu.store/payment/return
# PAYMENT_MODE=test

# Knowledge Assistant server-only secrets (Supabase Secrets, never VITE_*).
# KNOWLEDGE_CHAT_BASE_URL=
# KNOWLEDGE_CHAT_API_KEY=
# KNOWLEDGE_CHAT_MODEL=
# KNOWLEDGE_EMBEDDING_BASE_URL=
# KNOWLEDGE_EMBEDDING_API_KEY=
# KNOWLEDGE_EMBEDDING_MODEL=
# KNOWLEDGE_ALLOWED_ORIGINS=https://vilu.store
# KNOWLEDGE_PREVIEW_ORIGIN=https://your-vercel-preview.example
# RATE_LIMIT_SALT=
#
# Free Cloudflare Workers AI example (server-side only):
# KNOWLEDGE_CHAT_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CLOUDFLARE_ACCOUNT_ID>/ai/v1
# KNOWLEDGE_CHAT_API_KEY=<CLOUDFLARE_API_TOKEN>
# KNOWLEDGE_CHAT_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
# KNOWLEDGE_EMBEDDING_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CLOUDFLARE_ACCOUNT_ID>/ai/v1
# KNOWLEDGE_EMBEDDING_API_KEY=<CLOUDFLARE_API_TOKEN>
# KNOWLEDGE_EMBEDDING_MODEL=@cf/qwen/qwen3-embedding-0.6b
